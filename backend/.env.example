# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ashamitra?retryWrites=true&w=majority

# JWT signing — use a strong random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# Server
PORT=5000
OTP_EXPIRY_MINUTES=10

# Pilot mode returns OTP in the response body (dev convenience). Set USE_REAL_OTP=true in prod.
PILOT_MODE=true
USE_REAL_OTP=false

# Gemini API keys (rotated round-robin if quota hits)
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Groq (primary LLM for /api/chat)
GROQ_API_KEY=

# Google Cloud Text-to-Speech (Bengali voice)
# Get key: console.cloud.google.com → APIs & Services → Credentials → API Key
# Restrict to: Cloud Text-to-Speech API only
GOOGLE_TTS_API_KEY=
# Voice options. The DEFAULT bn-IN-Wavenet-A is distinctly INDIAN Bengali
# (West Bengal accent). Pilot listeners flagged that several Chirp3-HD
# voices — though smoother — lean Bangladeshi, which felt foreign to
# West Bengal ASHA workers. Leave GOOGLE_TTS_VOICE unset to use the
# Indian-accent default, OR pick an explicit override below.
#
# INDIAN-leaning (recommended for West Bengal pilots):
#   bn-IN-Wavenet-A          DEFAULT — clearly Indian female, conversational
#   bn-IN-Wavenet-B          Indian male
#
# Use with caution (smoother HD audio but accent leans Bangladeshi):
#   bn-IN-Chirp3-HD-Aoede    warm mid-pitch female (slightly neutral)
#   bn-IN-Chirp3-HD-Kore     mature female — leans Bangladeshi
#   bn-IN-Chirp3-HD-Leda     soft, slightly higher pitch — leans Bangladeshi
#   bn-IN-Chirp3-HD-Charon   deep male — leans Bangladeshi
#
# Leave commented to get the Indian-accent default:
# GOOGLE_TTS_VOICE=bn-IN-Wavenet-A
